{
  "mcpServers": {
    "filesystem": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["exec", "mcp-server-filesystem", "${workspaceFolder}"],
      "env": {}
    },
    "brp": {
      "type": "stdio",
      "command": "bevy_brp_mcp",
      "args": [],
      "env": {}
    },
    "aseprite": {
      "type": "stdio",
      "command": "proto",
      "args": ["run", "python", "3.13.9", "--", "-m", "aseprite_mcp"],
      "cwd": "${workspaceFolder}",
      "env": {}
    }
  }
}
