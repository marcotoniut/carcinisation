#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
watch_file "${repo_root}/.prototools"

if ! command -v proto >/dev/null 2>&1; then
  echo "direnv: proto is required but was not found in PATH" >&2
  exit 1
fi

cache_dir="${repo_root}/.direnv/cache"
mkdir -p "${cache_dir}"

fingerprint_file() { shasum -a 256 "$1" | awk '{print $1}'; }

run_once_per_fingerprint() {
  local key="$1"
  local value="$2"
  shift 2
  local stamp="${cache_dir}/${key}.stamp"
  local previous=""
  if [[ -f "${stamp}" ]]; then
    previous="$(cat "${stamp}")"
  fi
  if [[ "${previous}" == "${value}" ]]; then
    return 0
  fi
  "$@"
  printf '%s' "${value}" >"${stamp}"
}

run_once_per_fingerprint "proto-install" "$(fingerprint_file "${repo_root}/.prototools")" \
  proto install
